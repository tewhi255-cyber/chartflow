# Database (Railway auto-provides these via MYSQL_* vars)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chartflow
DB_USER=root
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_REFRESH_SECRET=change-this-to-another-random-secret

# Frontend URL (your Railway domain)
FRONTEND_URL=https://your-app.railway.app

# AWS S3 (optional - leave empty for local uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=chartflow-uploads

# SMTP (optional - for email verification and password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@chartflow.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Upload
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp,pdf,docx,xlsx,pptx,mp4,avi,mov,zip,rar
STORAGE_TYPE=local
