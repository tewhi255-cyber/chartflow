{
  "name": "chartflow",
  "version": "1.0.0",
  "private": true,
  "description": "ChartFlow Collaboration Platform",
  "scripts": {
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
